# ─────────────────────────────────────────────────────────────────────────────
# SulMotor – Backend API Environment Variables Reference
# Copy to api/.env and fill in your values. Never commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Production Access Token (starts with APP_USR-)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# Public Key (safe to expose in frontend too)
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Webhook signature secret (set in MP Dashboard → Webhooks)
# Leave blank to skip signature check during development
MP_WEBHOOK_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Comma-separated CORS origins
ALLOWED_ORIGIN=http://localhost:5173,https://sulmotor.com.br

# ── Supabase (for webhook boost activation) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service role key — keep SECRET, never expose to frontend
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
