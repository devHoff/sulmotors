# ──────────────────────────────────────────────────────────────────────────────
# SulMotor – Apache rewrite rules for React SPA (Hostinger shared hosting)
# ──────────────────────────────────────────────────────────────────────────────
#
# Without these rules the Apache server returns 404 for every client-side
# route (e.g. /auth/callback, /estoque, /carro/123) because it looks for a
# real file/directory at that path and finds nothing.
#
# The rules below tell Apache: if the requested path is NOT a real file or
# directory, serve index.html instead and let React Router handle the route.
# ──────────────────────────────────────────────────────────────────────────────

Options -MultiViews
RewriteEngine On

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Block MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Enable XSS protection in older browsers
    Header always set X-XSS-Protection "1; mode=block"
    # Only send referrer on same origin
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Gzip compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# ── MIME types ────────────────────────────────────────────────────────────────
AddType application/xml .xml
AddType text/plain .txt

# ── Static asset caching ──────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Vite builds assets with content-hash filenames — cache them for 1 year
    <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp)$">
        ExpiresDefault "access plus 1 year"
    </FilesMatch>
    # Favicon files: short cache so branding updates take effect quickly
    <FilesMatch "^(favicon.*|apple-touch-icon.*|sulmotor-logo.*)$">
        ExpiresDefault "access plus 1 day"
        Header set Cache-Control "public, max-age=86400, must-revalidate"
    </FilesMatch>
    # Never cache index.html so the browser always gets the latest app shell
    <FilesMatch "^index\.html$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ── SPA fallback: route all non-file requests to index.html ──────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Pass through real files (JS, CSS, images, fonts, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # NOTE: UUID → slug 301 redirects are handled client-side by React Router
    # (DetalheCarro.tsx detects a UUID param, fetches the slug, then calls
    # navigate(..., { replace: true }) which produces the canonical slug URL).
    # No server-side redirect is needed here because Apache cannot look up
    # the slug from the DB; the JS bundle handles it seamlessly.

    # Everything else → index.html (React Router takes over)
    RewriteRule ^ index.html [L]
</IfModule>
