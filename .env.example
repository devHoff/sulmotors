# ─────────────────────────────────────────────────────────────────────────────
# SulMotor – Environment Variables Reference
# Copy this file and fill in your values. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_STABILITY_API_KEY=your_stability_api_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# Mercado Pago Public Key (safe to expose in the frontend)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Payment API base URL (leave empty in dev — Vite proxy handles /api → localhost:3001)
# In production set to your real backend URL: https://api.sulmotor.com.br
VITE_PAYMENT_API_URL=
