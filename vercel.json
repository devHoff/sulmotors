{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "crons": [
    {
      "path": "/api/cron/expire-boosts",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/expire-pending-orders",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/update-scores",
      "schedule": "0 * * * *"
    }
  ],

  "functions": {
    "api/cron/expire-boosts.ts":          { "maxDuration": 30 },
    "api/cron/expire-pending-orders.ts":  { "maxDuration": 30 },
    "api/cron/update-scores.ts":          { "maxDuration": 60 }
  },

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],

  "env": {
    "NODE_ENV": "production"
  }
}
